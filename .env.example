# ═══════════════════════════════════════════════════════════════════════════
# Moigye Protocol — Environment Variables Reference
# Copy this file to .env and fill in the placeholder values.
# Or run:  node scripts/setup_env.js
# ═══════════════════════════════════════════════════════════════════════════

# ── Wallet ─────────────────────────────────────────────────────────────────
# Your deployer/signer private key with leading 0x
PRIVATE_KEY=""

# ── RPC Endpoints ──────────────────────────────────────────────────────────
# Sepolia RPC — get one from https://alchemy.com or https://infura.io
SEPOLIA_RPC_URL=""
# Creditcoin Testnet (pre-configured)
CTC_RPC_URL=https://rpc.cc3-testnet.creditcoin.network

# ── Hub Chain Contracts (Creditcoin Testnet — Chain ID: 102031) ────────────
GYE_MANAGER_ADDRESS=0xC6AF175200807DeE213f58D4C375a574284ba2f0
BIDDING_ENGINE_ADDRESS=0xa513E6E4b8f2a923D98304ec87F64353C4D5C853
SCORE_MANAGER_ADDRESS=0x0165878A594ca255338adfa4d48449f69242Eb8F
GYE_STAKING_ADDRESS=0x60CeeEb9A7172Fd20339692B19e0228087e17AA9
MOIGYE_SBT_ADDRESS=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D

# ── Spoke Chain Contracts (Ethereum Sepolia) ───────────────────────────────
MOIGYE_USD_ADDRESS=0x4ed7c06655c1b138c84014c119902c0039725807
# TODO: Run 'node scripts/deploy_vault_only.mjs' then paste the vault address:
MOIGYE_VAULT_ADDRESS=""

# ── Frontend / Auth ────────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ── Block Explorer Verification ────────────────────────────────────────────
# Required for 'npx hardhat verify' — get from https://etherscan.io/myapikey
ETHERSCAN_API_KEY=""
